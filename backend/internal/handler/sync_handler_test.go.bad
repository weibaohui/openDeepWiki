// TestSyncHandler_RequestValidation 测试请求验证
func TestSyncHandler_RequestValidation(t *testing.T) {
	gin.SetMode(gin.TestMode)
	// Add recovery middleware to handle panics from nil service
	router.Use(gin.Recovery())
	router := gin.New()

	h := NewSyncHandler(nil)

	api := router.Group("/api/v1/sync")
	h.RegisterRoutes(api)

	tests := []struct {
		name           string
		endpoint       string
		requestBody    string
		expectedStatus int
	}{
		{
			name:           "无效的JSON - Start",
			endpoint:       "/api/v1/sync",
			requestBody:    "invalid json",
			expectedStatus: http.StatusBadRequest,
		},
		{
			name:           "无效的JSON - Pull",
			endpoint:       "/api/v1/sync/pull",
			requestBody:    "invalid json",
			expectedStatus: http.StatusBadRequest,
		},
		{
			name:           "无效的JSON - TargetSave",
			endpoint:       "/api/v1/sync/target-save",
			requestBody:    "invalid json",
			expectedStatus: http.StatusBadRequest,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			req, _ := http.NewRequest(http.MethodPost, tt.endpoint, bytes.NewBufferString(tt.requestBody))
			req.Header.Set("Content-Type", "application/json")

			w := httptest.NewRecorder()
			router.ServeHTTP(w, req)

			assert.Equal(t, tt.expectedStatus, w.Code)
		})
	}
}

// TestSyncHandler_MissingRequiredFields 测试缺少必填字段
func TestSyncHandler_MissingRequiredFields(t *testing.T) {
	gin.SetMode(gin.TestMode)
	// Add recovery middleware to handle panics from nil service
	router.Use(gin.Recovery())
	router := gin.New()

	h := NewSyncHandler(nil)

	api := router.Group("/api/v1/sync")
	h.RegisterRoutes(api)

	tests := []struct {
		name           string
		endpoint       string
		requestBody    map[string]interface{}
		expectedStatus int
	}{
		{
			name:     "Start - 缺少repository_id",
			endpoint: "/api/v1/sync",
			requestBody: map[string]interface{}{
				"target_server": "http://target-server/api/sync",
			},
			expectedStatus: http.StatusBadRequest,
		},
		{
			name:     "DocumentList - 缺少repository_id",
			endpoint: "/api/v1/sync/document-list",
			requestBody: map[string]interface{}{},
		},
		{
			name:     "RepositoryClear - 缺少repository_id",
			endpoint: "/api/v1/sync/repository-clear",
			requestBody: map[string]interface{}{},
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			var req *http.Request
			if tt.requestBody != nil {
				body, _ := json.Marshal(tt.requestBody)
				req, _ = http.NewRequest(http.MethodPost, tt.endpoint, bytes.NewReader(body))
				req.Header.Set("Content-Type", "application/json")
			} else {
				req, _ = http.NewRequest(http.MethodGet, tt.endpoint, nil)
			}

			w := httptest.NewRecorder()
			router.ServeHTTP(w, req)

			assert.Equal(t, tt.expectedStatus, w.Code)
		})
	}
}

// TestSyncHandler_Routes 测试路由注册
func TestSyncHandler_Routes(t *testing.T) {
	gin.SetMode(gin.TestMode)
	// Add recovery middleware to handle panics from nil service
	router.Use(gin.Recovery())
	router := gin.New()

	h := NewSyncHandler(nil)
	h.RegisterRoutes(router.Group("/api/v1/sync"))

	// Check that routes are registered
	routes := router.Routes()

	expectedRoutes := []string{
		"/api/v1/sync/ping",
		"/api/v1/sync",
		"/api/v1/sync/pull",
		"/api/v1/sync/status/:sync_id",
		"/api/v1/sync/event-list",
		"/api/v1/sync/repository-list",
		"/api/v1/sync/document-list",
		"/api/v1/sync/target-list",
		"/api/v1/sync/target-save",
		"/api/v1/sync/target-delete",
		"/api/v1/sync/pull-export",
		"/api/v1/sync/repository-upsert",
		"/api/v1/sync/repository-clear",
		"/api/v1/sync/task-create",
		"/api/v1/sync/document-create",
		"/api/v1/sync/task-update-docid",
		"/api/v1/sync/task-usage-create",
	}

	routePaths := make(map[string]bool)
	for _, route := range routes {
		routePaths[route.Path] = true
	}

	for _, expectedRoute := range expectedRoutes {
		assert.True(t, routePaths[expectedRoute], "Route %s should be registered", expectedRoute)
	}
}

